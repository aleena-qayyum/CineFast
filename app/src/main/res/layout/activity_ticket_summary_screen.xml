<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMovieName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Movie Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Seat Count -->
        <TextView
            android:id="@+id/tvSeatCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seats: 0"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvSeatPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seat Price: Rs. 0"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"/>

        <!-- Snack Price -->
        <TextView
            android:id="@+id/tvSnackPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Snack Price: Rs. 0"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"/>

        <!-- Total Price -->
        <TextView
            android:id="@+id/tvTotalPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Price: Rs. 0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"/>

        <!-- Send Ticket Button -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send Ticket"
            android:backgroundTint="#FF0000"
            android:textColor="@android:color/white"/>

    </LinearLayout>
</ScrollView>